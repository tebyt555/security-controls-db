{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "active", "deprecated"] },
    "owner": { "type": "string" },
    "automated_evidence": { "type": "boolean" }
  },
  "required": ["id", "title", "status", "owner"]
}